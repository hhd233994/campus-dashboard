/mvnw text eol=lf
*.cmd text eol=crlf

# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized
*.java text
*.properties text
*.xml text
*.yml text
*.yaml text
*.sql text
*.md text
*.html text
*.css text
*.js text

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
