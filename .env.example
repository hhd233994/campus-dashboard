# 数据库配置
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# JWT配置 (至少256位随机字符串)
JWT_SECRET=generate_a_strong_random_secret_here_min_256_bits

# Redis配置 (可选)
REDIS_PASSWORD=optional_redis_password

# 使用说明:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改 .env 中的值为实际的安全凭证
# 3. .env 文件已在 .gitignore 中,不会被提交到Git
